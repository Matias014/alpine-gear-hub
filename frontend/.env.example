# Copy this file to .env and fill in the values before running `npm run dev`.
# Without a real key, the promotion checkout UI renders but Stripe.js itself fails to load.

# Stripe test-mode publishable key — pairs with the backend's STRIPE_SECRET_KEY, get both from
# https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
