# Copy this file to .env and fill in the values before running docker compose.
# The defaults in docker-compose.yml are fine for local development.

# JWT signing secret — use a long random string in any real deployment
JWT_SECRET=change-this-secret-before-going-to-production

# Stripe test-mode keys — get them from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
